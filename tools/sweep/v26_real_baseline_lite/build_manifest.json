{
  "metadata": {
    "type": "baseline",
    "description": "Fixed center-point parameters with varying random seeds",
    "n_samples": 30,
    "seed_start": 1,
    "n_parameters": 16,
    "center_points": {
      "economic_split": 0.5,
      "hashrate_split": 0.5,
      "pool_ideology_strength": 0.5,
      "pool_profitability_threshold": 0.16,
      "pool_max_loss_pct": 0.26,
      "pool_committed_split": 0.5,
      "pool_neutral_pct": 30.0,
      "econ_ideology_strength": 0.4,
      "econ_switching_threshold": 0.135,
      "econ_inertia": 0.175,
      "user_ideology_strength": 0.5,
      "user_switching_threshold": 0.125,
      "transaction_velocity": 0.5,
      "user_nodes_per_partition": 6,
      "economic_nodes_per_partition": 2,
      "solo_miner_hashrate": 0.085
    },
    "parameters": [
      {
        "name": "economic_split",
        "min": 0.0,
        "max": 1.0,
        "type": "continuous",
        "description": "Fraction of economic custody starting on v27"
      },
      {
        "name": "hashrate_split",
        "min": 0.0,
        "max": 1.0,
        "type": "continuous",
        "description": "Fraction of initial hashrate starting on v27"
      },
      {
        "name": "pool_ideology_strength",
        "min": 0.1,
        "max": 0.9,
        "type": "continuous",
        "description": "How much pools sacrifice for ideology"
      },
      {
        "name": "pool_profitability_threshold",
        "min": 0.02,
        "max": 0.3,
        "type": "continuous",
        "description": "Min profit advantage for pools to consider switching"
      },
      {
        "name": "pool_max_loss_pct",
        "min": 0.02,
        "max": 0.5,
        "type": "continuous",
        "description": "Max revenue loss pools tolerate for ideology"
      },
      {
        "name": "pool_committed_split",
        "min": 0.0,
        "max": 1.0,
        "type": "continuous",
        "description": "Fraction of committed pool hashrate preferring v27"
      },
      {
        "name": "pool_neutral_pct",
        "min": 10,
        "max": 50,
        "type": "continuous",
        "description": "Percentage of pools that are neutral/rational"
      },
      {
        "name": "econ_ideology_strength",
        "min": 0.0,
        "max": 0.8,
        "type": "continuous",
        "description": "How much economic nodes sacrifice for ideology"
      },
      {
        "name": "econ_switching_threshold",
        "min": 0.02,
        "max": 0.25,
        "type": "continuous",
        "description": "Min price advantage for economic nodes to switch"
      },
      {
        "name": "econ_inertia",
        "min": 0.05,
        "max": 0.3,
        "type": "continuous",
        "description": "Additional switching friction (infrastructure costs)"
      },
      {
        "name": "user_ideology_strength",
        "min": 0.1,
        "max": 0.9,
        "type": "continuous",
        "description": "How much users sacrifice for ideology"
      },
      {
        "name": "user_switching_threshold",
        "min": 0.05,
        "max": 0.2,
        "type": "continuous",
        "description": "Min price advantage for users to switch"
      },
      {
        "name": "transaction_velocity",
        "min": 0.1,
        "max": 0.9,
        "type": "continuous",
        "description": "Rate of fee-generating transactions"
      },
      {
        "name": "user_nodes_per_partition",
        "min": 2,
        "max": 10,
        "type": "discrete",
        "description": "Number of user nodes per partition"
      },
      {
        "name": "economic_nodes_per_partition",
        "min": 1,
        "max": 3,
        "type": "discrete",
        "description": "Number of economic/exchange nodes per partition"
      },
      {
        "name": "solo_miner_hashrate",
        "min": 0.02,
        "max": 0.15,
        "type": "continuous",
        "description": "Hashrate percentage per solo miner"
      }
    ]
  },
